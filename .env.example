# Web and cloud services
NEXT_PUBLIC_CLOUD_API_URL=http://localhost:3000/api
NEXT_PUBLIC_BRANCH_HUB_URL=http://127.0.0.1:4310
NEXT_PUBLIC_BRANCH_HUB_TOKEN=replace-with-branch-device-token
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key
SUPABASE_SECRET_KEY=replace-with-local-secret-key

# Branch hub
HOST=127.0.0.1
PORT=4310
HUB_DATABASE_PATH=./data/cafepos.sqlite
HUB_OUTBOX_PATH=./data/outbox.json
