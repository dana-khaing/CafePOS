HUB_BRANCH_TOKEN=replace-with-branch-device-token
HUB_WEB_ORIGINS=http://localhost:3000
HUB_ALLOW_LAN=false

# Optional provider adapters
EMAIL_PROVIDER=console
RESEND_API_KEY=
