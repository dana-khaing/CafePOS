{
  "name": "cafepos",
  "version": "0.0.0",
  "private": true,
  "description": "Offline-first multi-branch cafe and restaurant point-of-sale system",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "prettier": "3.6.2",
    "turbo": "2.5.5",
    "typescript": "5.8.3"
  }
}
